# Lean MariaDB settings for the single-container Verwandlung Online Judge demo.
# Trimmed for a small RAM footprint, not for throughput — raise these (or drop
# this file) for a real deployment.
[mysqld]
# performance_schema alone can cost a few hundred MB of RAM; the demo does not
# need its instrumentation.
performance_schema      = OFF
# The demo dataset is tiny, so a small buffer pool is plenty.
innodb_buffer_pool_size = 64M
# Matches the (small) Druid connection pools of the web app and the judger.
max_connections         = 20
key_buffer_size         = 8M
tmp_table_size          = 8M
max_heap_table_size     = 8M

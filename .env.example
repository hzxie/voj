# Copy to .env and edit for docker-compose.yml. Compose reads .env automatically;
# every value here is optional (the compose file has sensible defaults).

# Host port to publish the web UI on.
VOJ_HTTP_PORT=8080

# Public root used in e-mails and absolute links. Behind a reverse proxy set this
# to the externally visible URL, e.g. https://oj.example.edu, and set the context
# path to / to serve at the root.
VOJ_BASE_URL=http://localhost:8080/voj
VOJ_CONTEXT_PATH=/voj

# Shared secret the judger presents to download a problem's test data. Use a long
# random value for anything but a local trial (the web and judger read the same one).
VOJ_JUDGER_API_TOKEN=verwandlung

# SMTP (leave empty to disable e-mail, e.g. password-reset mails).
VOJ_MAIL_HOST=
VOJ_MAIL_USERNAME=
VOJ_MAIL_PASSWORD=
VOJ_MAIL_SENDER=noreply@example.com

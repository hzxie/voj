# File Generated by Mac
.DS_Store

# Generated per-OS judger test config: CI (appveyor/circleci/github) and
# scripts/test-local.* copy voj-test-{windows,linux}.properties to this file
# before running the tests, so it must never be committed. (The web module's
# voj-test.properties IS committed, hence the judger-only path.)
/judger/src/test/resources/voj-test.properties

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.verwandlung.voj.web.mapper.OffensiveWordMapper">
	<!-- Methods -->
	<select id="getOffensiveWords"
		resultType="java.lang.String">
		SELECT word
		FROM voj_offensive_words
	</select>
	<select id="getNumberOfOffensiveWords"
		resultType="long">
		SELECT COUNT(*)
		FROM voj_offensive_words
	</select>
	<delete id="deleteAllOffensiveWords">
		DELETE FROM voj_offensive_words
	</delete>
	<insert id="batchCreateOffensiveWords"
		parameterType="map">
		<!-- IGNORE skips words that collide with an existing row under the column's
		     case- and accent-insensitive collation (utf8mb4_unicode_ci), e.g. "K粉" and
		     "k粉", which the Java-side set de-duplicates only case-sensitively. -->
		INSERT IGNORE INTO voj_offensive_words (word)
		VALUES
		<foreach collection="offensiveWords" item="word" separator=",">
			(#{word})
		</foreach>
	</insert>
</mapper>
